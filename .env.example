# ── 환경 변수 예시 (git 에 포함) ──
# 실제 값은 .env.local 에 작성하세요(.env.local 은 git 추적 제외).

# 국토교통부 실거래가 API 키 (공공데이터포털 일반 인증키 Decoding)
MOLIT_API_KEY=your_molit_api_key_here

# Redis 캐시 URL (선택, 미설정 시 캐싱 비활성화)
REDIS_URL=redis://localhost:6379

# Google AdSense 게시자 ID
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-your_id_here

# 사이트 기본 URL (배포 도메인)
NEXT_PUBLIC_SITE_URL=https://apt.healthfy.com

# Google Analytics 4 측정 ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
